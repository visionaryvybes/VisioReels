{"title":"...","logline":"...","hook":"...","palette":["#hex","#hex","#hex"],"typography":{"headline_font":"...","mono_font":"..."},"motion_language":"...","overall_energy":"electric|raw|cinematic|minimal|dramatic","scenes":[{"layout":"editorial|hud|typographic|split|orbital|full-bleed|glitch|magazine","bg":"image path or gradient","headline":"SPECIFIC HEADLINE — what this image actually shows","kicker":"short supporting line","body":"","accent":"#hex","primitives":[],"transition":"slide-right|slide-left|fade|wipe|flip|iris|clock-wipe","motion_note":""}]}

[ROLE: reel]
